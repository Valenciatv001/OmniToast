{
  "name": "@modal-toast/native",
  "version": "0.1.0",
  "description": "Expo / React Native adapter for modal-toast — animated toasts and modal dialogs",
  "keywords": ["toast", "modal", "notification", "react-native", "expo"],
  "author": "",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-native",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-native",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modal-toast/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-native": ">=0.72",
    "react-native-safe-area-context": ">=4"
  },
  "peerDependenciesMeta": {
    "react-native-safe-area-context": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "@types/react": "^18.3.18",
    "react": "^18.3.1"
  }
}
